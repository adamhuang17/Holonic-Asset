SERVER_HOST=127.0.0.1
SERVER_PORT=8080
OUTPUT_DIR=./outputs
PUBLIC_BASE_URL=
MAX_UPLOAD_BYTES=10485760

# true: run the complete local workflow without calling QNAIGC.
# false: use QNAIGC_API_KEY and call the real image edit endpoint once.
ANIMATION_MOCK_PROVIDER=true

QNAIGC_BASE_URL=https://api.qnaigc.com
QNAIGC_API_KEY=
QNAIGC_MODEL=openai/gpt-image-2
QNAIGC_SIZE=1536x1024
QNAIGC_QUALITY=low
QNAIGC_OUTPUT_FORMAT=png
QNAIGC_TIMEOUT_SECONDS=240
